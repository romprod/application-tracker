{
  "name": "application-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "A self-hosted workspace for tracking job applications and outcomes.",
  "license": "Elastic-2.0",
  "homepage": "https://github.com/romprod/application-tracker#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/romprod/application-tracker.git"
  },
  "bugs": {
    "url": "https://github.com/romprod/application-tracker/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "npm run clean && npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run build",
    "clean": "node scripts/clean.mjs",
    "db:backup": "node dist/server/server/database_maintenance.js backup",
    "db:restore": "node dist/server/server/database_maintenance.js restore",
    "db:verify": "node dist/server/server/database_maintenance.js verify",
    "dev": "concurrently -k -n server,client -c cyan,magenta \"tsx watch src/server/http.ts\" \"vite\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "start": "node dist/server/server/http.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.client.json && tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.tools.json"
  },
  "dependencies": {
    "@fontsource-variable/archivo": "5.2.8",
    "@fontsource-variable/newsreader": "5.2.10",
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-sqlite3": "12.11.1",
    "compression": "1.8.1",
    "cookie": "2.0.1",
    "express": "5.2.1",
    "helmet": "8.3.0",
    "jose": "6.2.3",
    "multer": "2.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/compression": "1.8.1",
    "@types/express": "5.0.6",
    "@types/multer": "2.2.0",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/supertest": "7.2.1",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "supertest": "7.2.2",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
