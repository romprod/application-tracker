# Listen on every interface for LAN and container access.
HOST=0.0.0.0
PORT=3333

# Keep runtime data outside the source tree in production.
DATABASE_PATH=./data/application-tracker.sqlite

# Online backups are written here when db:backup has no --output argument.
BACKUP_DIRECTORY=./backups

# Session policy: 30-minute idle timeout and 24-hour absolute timeout.
SESSION_IDLE_SECONDS=1800
SESSION_ABSOLUTE_SECONDS=86400
SESSION_REFRESH_SECONDS=60
# Defaults to true when NODE_ENV=production; set explicitly behind HTTPS.
SESSION_COOKIE_SECURE=false

# Optional local stdio binding. Set both values in each MCP client's private
# environment; a fresh installation uses the workspace slug "default".
MCP_LOCAL_ACTOR_USERNAME=
MCP_LOCAL_WORKSPACE_SLUG=

# Closed remote MCP session policy. The registry enforces these limits before
# initialization; no remote endpoint is enabled yet.
MCP_SESSION_GLOBAL_LIMIT=6
MCP_SESSION_PER_ACTOR_LIMIT=2
MCP_SESSION_IDLE_SECONDS=900
MCP_SESSION_ABSOLUTE_SECONDS=14400

# Generate a unique token with: openssl rand -hex 32
# Remove it after creating the first administrator.
SETUP_TOKEN=
