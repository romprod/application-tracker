# Listen on every interface for LAN and container access.
HOST=0.0.0.0
PORT=3333

# Keep runtime data outside the source tree in production.
DATABASE_PATH=./data/application-tracker.sqlite

# Online backups are written here when db:backup has no --output argument.
BACKUP_DIRECTORY=./backups

# Process-local source limit across website, API, and remote MCP requests.
# Leave proxy hops at zero for direct access. Set the exact trusted hop count
# only when every request reaches the app through that fixed proxy chain.
HTTP_RATE_LIMIT_REQUESTS=600
HTTP_RATE_LIMIT_WINDOW_SECONDS=60
HTTP_TRUST_PROXY_HOPS=0

# Original document upload limit in bytes (default 10 MiB; range 1 KiB-50 MiB).
DOCUMENT_MAX_UPLOAD_BYTES=10485760
# Uploads buffered at once across this process (default 2; range 1-32).
DOCUMENT_MAX_CONCURRENT_UPLOADS=2

# Cumulative document quotas. Installation limits must be at least the
# workspace limits; the workspace byte limit must cover one maximum upload.
DOCUMENT_MAX_WORKSPACE_BYTES=536870912
DOCUMENT_MAX_WORKSPACE_COUNT=2000
DOCUMENT_MAX_INSTALLATION_BYTES=2147483648
DOCUMENT_MAX_INSTALLATION_COUNT=10000

# Isolated document-preview process limits. The input limit cannot exceed the
# upload limit. Decoded bytes cap selected DOCX content. Memory applies to each
# process; concurrency applies process-wide.
DOCUMENT_PREVIEW_MAX_CONCURRENT_WORKERS=2
DOCUMENT_PREVIEW_MAX_INPUT_BYTES=1048576
DOCUMENT_PREVIEW_MAX_DECODED_BYTES=8388608
DOCUMENT_PREVIEW_MAX_OUTPUT_CHARACTERS=100000
DOCUMENT_PREVIEW_TIMEOUT_MS=1500
DOCUMENT_PREVIEW_MAX_MEMORY_MB=32

# Login and session policy: ten admitted attempts per source and account each
# minute, two simultaneous password verifications, a 30-minute idle timeout,
# and a 24-hour absolute timeout.
LOGIN_RATE_LIMIT_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_MAX_KEYS=10000
LOGIN_MAX_CONCURRENT_VERIFICATIONS=2
SESSION_IDLE_SECONDS=1800
SESSION_ABSOLUTE_SECONDS=86400
SESSION_REFRESH_SECONDS=60
# Defaults to true when NODE_ENV=production; set explicitly behind HTTPS.
SESSION_COOKIE_SECURE=false

# Optional local stdio binding. Set both values in each MCP client's private
# environment; a fresh installation uses the workspace slug "default".
MCP_LOCAL_ACTOR_USERNAME=
MCP_LOCAL_WORKSPACE_SLUG=
MCP_LOCAL_ACCESS_MODE=read_only

# Remote MCP session policy. The registry enforces these limits before
# initialization when the remote endpoint is enabled.
MCP_SESSION_GLOBAL_LIMIT=256
MCP_SESSION_PER_ACTOR_LIMIT=64
MCP_SESSION_IDLE_SECONDS=300
MCP_SESSION_ABSOLUTE_SECONDS=14400

# Remote MCP request controls. Concurrency uses the authenticated actor; the
# rate budget belongs to each authorized connection and includes protocol
# traffic as well as tool calls. The per-actor concurrency limit must be lower
# than the global limit.
MCP_REMOTE_MAX_REQUEST_BYTES=65536
MCP_REMOTE_MAX_CONCURRENT_REQUESTS=64
MCP_REMOTE_MAX_CONCURRENT_REQUESTS_PER_ACTOR=32
MCP_REMOTE_RATE_LIMIT_REQUESTS=600
MCP_REMOTE_RATE_LIMIT_WINDOW_SECONDS=60

# Optional external OAuth token verifier. The built-in local-account OAuth flow
# is enabled with remote MCP and needs none of these values. Configure all six
# only when also accepting tokens from an existing external identity provider.
MCP_OAUTH_ALGORITHM=
MCP_OAUTH_AUDIENCE=
MCP_OAUTH_ISSUER=
MCP_OAUTH_JWKS_URL=
MCP_OAUTH_REQUIRED_SCOPE=
MCP_OAUTH_WORKSPACE_SLUG=

# Remote Streamable HTTP remains disabled unless this flag and all three network
# values are set. Use the public HTTPS resource URL ending in /mcp.
MCP_REMOTE_ENABLED=false
MCP_REMOTE_URL=
MCP_REMOTE_ALLOWED_HOSTS=
MCP_REMOTE_ALLOWED_ORIGINS=

# Generate a unique token with: openssl rand -hex 32
# Remove it after creating the first administrator.
SETUP_TOKEN=
